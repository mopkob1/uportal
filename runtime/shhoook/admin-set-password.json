{
  "uri": "/admin/set-password",
  "method": "POST",
  "auth": "X-Token:CHANGE_ME_UPORTAL_ADMIN_SECRET",
  "ttl": "15s",
  "error": 500,
  "query" : {
    "user_token" : "notoken"
  },
  "body": {
    "password": "",
    "password_hint": "",
    "password_ttl_sec": "1800"
  },
  "script": [
    "bash",
    "/usr/local/bin/admin-set-password.sh",
    "{publication_id}",
    "{token}",
    "{password}",
    "{password_hint}",
    "{password_ttl_sec}",
    "{user_token}"
  ]
}
