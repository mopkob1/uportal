{
  "uri": "/publish/page",
  "method": "POST",
  "auth": "X-Token:CHANGE_ME_UPORTAL_ADMIN_SECRET",
  "ttl": "60s",
  "error": 500,
  "query" : {
    "user_token" : "notoken",
    "client_uid": "",
    "client_type": ""
  },
  "body": {
    "type": "page",
    "status": "active",
    "mails": "[]",
    "fresh_until": "-1",
    "remaining_clicks": "-1",
    "fallback_url": "__UPORTAL_BASE_URL__/link-fallback",
    "image": "",
    "title": "",
    "description": "",
    "page_ttl_sec": "1800",
    "password_hint": "",
    "password_ttl_sec": "1800",
    "pre": "",
    "post": "",
    "sticky": "",
    "lang": "en"
  },
  "script": [
    "bash",
    "/usr/local/bin/publish-page.sh",
    "{type}",
    "{status}",
    "{publication_id}",
    "{token}",
    "{short}",
    "{subj}",
    "{mails}",
    "{link}",
    "{entry_md}",
    "{image}",
    "{title}",
    "{description}",
    "{page_ttl_sec}",
    "{fresh_until}",
    "{remaining_clicks}",
    "{fallback_url}",
    "{password}",
    "{password_hint}",
    "{password_ttl_sec}",
    "{user_token}",
    "{pre}",
    "{post}",
    "{sticky}",
    "{client_uid}",
    "{client_type}",
    "{lang}"
  ]
}
