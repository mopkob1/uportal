{
  "uri": "/tokens/self",
  "method": "POST",
  "auth": "X-Token:CHANGE_ME_UPORTAL_ADMIN_SECRET",
  "ttl": "60s",
  "error": 500,
  "query": {
    "user_token": "notoken"
  },
  "body": {
    "payload_b64": ""
  },
  "script": [
    "bash",
    "/usr/local/bin/uportal-token-self-upsert.sh",
    "{user_token}",
    "{payload_b64}"
  ]
}
