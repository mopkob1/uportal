UPORTAL_DOMAIN=links.example.com
UPORTAL_BASE_URL=https://links.example.com
UPORTAL_HTTP_PORT=18080
UPORTAL_BIND_ADDR=127.0.0.1
UPORTAL_DATA_DIR=./data/files
UPORTAL_UI_LANG=en

# Defaults to UPORTAL_BASE_URL. Set explicitly when building plugin for another
# default server URL.
UPORTAL_PLUGIN_DEFAULT_BASE_URL=https://links.example.com

# Optional. Leave empty to generate on first container start.
UPORTAL_ADMIN_SECRET=
UPORTAL_DOWNLOAD_SALT=
UPORTAL_STAT_SECRET=
UPORTAL_PAGE_SECRET=
UPORTAL_INTERNAL_KEY=
UPORTAL_N8N_URL=

# Commercial bridge defaults are hardcoded in the container:
#   UPORTAL_COMMERCIAL_BRIDGE_URL=https://u.1qr.org/api/community/register-plugin
#   UPORTAL_COMMERCIAL_BRIDGE_TIMEOUT=3
#
# To override them, set the marker below to rewr1te and provide replacement
# values. Without this marker, the container ignores the URL/timeout values.
UPORTAL_COMMERCIAL_BRIDGE=
UPORTAL_COMMERCIAL_BRIDGE_URL=https://u.1qr.org/api/community/register-plugin
UPORTAL_COMMERCIAL_BRIDGE_TIMEOUT=3
